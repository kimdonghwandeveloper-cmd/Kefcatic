# Database
DATABASE_URL=postgresql+asyncpg://dev:dev@localhost/assistant_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Fernet key for encrypting connector credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Connector OAuth redirect URIs (Google connectors reuse GOOGLE_CLIENT_ID/SECRET)
GMAIL_REDIRECT_URI=http://localhost:8000/api/connectors/gmail/callback
DRIVE_REDIRECT_URI=http://localhost:8000/api/connectors/google-drive/callback
CALENDAR_REDIRECT_URI=http://localhost:8000/api/connectors/google-calendar/callback
SHEETS_REDIRECT_URI=http://localhost:8000/api/connectors/google-sheets/callback

# Connector OAuth — Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/connectors/slack/callback

# Connector OAuth — HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/api/connectors/hubspot/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/github/callback

# LLM
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Environment
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:5173"]

# Frontend API base (for Vite dev proxy)
VITE_API_BASE_URL=http://localhost:8000
